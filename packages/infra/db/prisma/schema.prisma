generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  EDITOR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PENDING_DEPOSIT
  CANCELLED
  NO_SHOW
}

enum DeployStatus {
  PENDING
  BUILDING
  DEPLOYED
  FAILED
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  passwordHash    String?
  avatarUrl       String?
  role            Role            @default(OWNER)
  sites           Site[]
  assignedChanges ChangeRequest[] @relation("AssignedTo")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("users")
}

enum ClientPlan {
  BASIC
  PREMIUM
  ENTERPRISE
  CUSTOM
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  GRACE
}

enum ChangeStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Client {
  id              String        @id @default(cuid())
  name            String        // Business name
  contactPerson   String
  email           String
  phone           String?
  whatsapp        String?
  plan            ClientPlan    @default(BASIC)
  monthlyPrice    Int           @default(0)   // In smallest currency unit
  currency        String        @default("IDR")
  paymentStatus   PaymentStatus @default(PENDING)
  paymentDueDate  DateTime?
  lastPaymentDate DateTime?
  notes           String?
  sites           Site[]
  changeRequests  ChangeRequest[]
  invoices        Invoice[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([paymentStatus])
  @@map("clients")
}

model Site {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  template        String
  domain          String?           @unique
  vercelProjectId String?
  deployStatus    DeployStatus      @default(PENDING)
  owner           User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId         String
  client          Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId        String?
  content         Json              @default("{}")
  themeOverrides  Json?
  integrations    SiteIntegration[]
  qaReports       QAReport[]
  deployments     Deployment[]
  bookings        Booking[]
  changeRequests  ChangeRequest[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([ownerId])
  @@index([clientId])
  @@index([template])
  @@map("sites")
}

model ChangeRequest {
  id          String       @id @default(cuid())
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  site        Site?        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  siteId      String?
  title       String
  description String
  priority    String       @default("normal") // low, normal, high, urgent
  status      ChangeStatus @default(PENDING)
  assignedTo  User?        @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String?
  requestedAt DateTime     @default(now())
  completedAt DateTime?
  notes       String?

  @@index([clientId])
  @@index([status])
  @@index([assignedToId])
  @@map("change_requests")
}

model Invoice {
  id          String        @id @default(cuid())
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  amount      Int           // In smallest currency unit
  currency    String        @default("IDR")
  period      String        // "2026-03" (month)
  status      InvoiceStatus @default(DRAFT)
  dueDate     DateTime
  paidDate    DateTime?
  notes       String?
  createdAt   DateTime      @default(now())

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model SiteIntegration {
  id          String   @id @default(cuid())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String
  integration String
  enabled     Boolean  @default(true)
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteId, integration])
  @@index([siteId])
  @@map("site_integrations")
}

model QAReport {
  id          String   @id @default(cuid())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String
  healthScore Int
  report      Json
  createdAt   DateTime @default(now())

  @@index([siteId])
  @@index([createdAt])
  @@map("qa_reports")
}

model Booking {
  id            String        @id @default(cuid())
  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId        String
  sectionType   String        @default("reservation") // "reservation", "booking", "appointment"
  date          String        // "2026-03-20" (ISO date string)
  time          String        // "19:00"
  guestName     String
  guestPhone    String
  guestEmail    String?
  partySize     Int           @default(1)
  status        BookingStatus @default(PENDING)
  depositAmount Int?          // In smallest currency unit (cents/rupiah)
  depositPaid   Boolean       @default(false)
  paymentId     String?       // External payment reference
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([siteId, date])
  @@index([siteId, status])
  @@index([createdAt])
  @@map("bookings")
}

model Deployment {
  id              String       @id @default(cuid())
  site            Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId          String
  status          DeployStatus @default(PENDING)
  vercelDeployId  String?
  url             String?
  commitMessage   String?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  @@index([siteId])
  @@index([createdAt])
  @@map("deployments")
}
