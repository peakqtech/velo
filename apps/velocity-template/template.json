{
  "name": "velocity",
  "displayName": "Velocity",
  "description": "Athletic/Sportswear — Cinematic Dark theme with scroll-driven animations",
  "businessType": "Athletic/Sportswear",
  "style": "Cinematic Dark",
  "contentType": "VelocityContent",
  "sections": {
    "@velo/hero": {
      "component": "Hero",
      "configExport": "heroScrollConfig",
      "contentKey": "hero"
    },
    "@velo/product-showcase": {
      "component": "ProductShowcase",
      "configExport": "productShowcaseScrollConfig",
      "contentKey": "productShowcase"
    },
    "@velo/brand-story": {
      "component": "BrandStory",
      "configExport": "brandStoryScrollConfig",
      "contentKey": "brandStory"
    },
    "@velo/product-grid": {
      "component": "ProductGrid",
      "configExport": "productGridScrollConfig",
      "contentKey": "productGrid"
    },
    "@velo/testimonials": {
      "component": "Testimonials",
      "configExport": "testimonialsScrollConfig",
      "contentKey": "testimonials"
    },
    "@velo/footer": {
      "component": "Footer",
      "configExport": "footerScrollConfig",
      "contentKey": "footer",
      "extraProps": { "localeSwitcher": "<LocaleSwitcher />" }
    }
  }
}
