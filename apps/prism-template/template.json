{
  "name": "prism",
  "displayName": "Prism",
  "description": "SaaS/Marketplace — Flat Clean theme with purple primary, rounded corners, and soft shadows",
  "businessType": "SaaS/Marketplace",
  "style": "Flat Clean",
  "contentType": "PrismContent",
  "sections": {
    "@velo/prism-hero": {
      "component": "PrismHero",
      "configExport": "prismHeroScrollConfig",
      "contentKey": "hero"
    },
    "@velo/prism-features": {
      "component": "PrismFeatures",
      "configExport": "prismFeaturesScrollConfig",
      "contentKey": "features"
    },
    "@velo/prism-pricing": {
      "component": "PrismPricing",
      "configExport": "prismPricingScrollConfig",
      "contentKey": "pricing"
    },
    "@velo/prism-integrations": {
      "component": "PrismIntegrations",
      "configExport": "prismIntegrationsScrollConfig",
      "contentKey": "integrations"
    },
    "@velo/prism-testimonials": {
      "component": "PrismTestimonials",
      "configExport": "prismTestimonialsScrollConfig",
      "contentKey": "testimonials"
    },
    "@velo/prism-faq": {
      "component": "PrismFAQ",
      "configExport": "prismFAQScrollConfig",
      "contentKey": "faq"
    },
    "@velo/prism-footer": {
      "component": "PrismFooter",
      "configExport": "prismFooterScrollConfig",
      "contentKey": "footer",
      "extraProps": { "localeSwitcher": "<LocaleSwitcher />" }
    }
  }
}
