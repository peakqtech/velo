{
  "name": "serenity",
  "displayName": "Serenity",
  "description": "Healthcare/Wellness — Soft UI theme with sage green primary, lavender accent, rounded elements, and calming colors",
  "businessType": "Healthcare/Wellness",
  "style": "Soft UI",
  "contentType": "SerenityContent",
  "sections": {
    "@velo/serenity-hero": {
      "component": "SerenityHero",
      "configExport": "serenityHeroScrollConfig",
      "contentKey": "hero"
    },
    "@velo/serenity-services": {
      "component": "SerenityServices",
      "configExport": "serenityServicesScrollConfig",
      "contentKey": "services"
    },
    "@velo/serenity-process": {
      "component": "SerenityProcess",
      "configExport": "serenityProcessScrollConfig",
      "contentKey": "process"
    },
    "@velo/serenity-practitioners": {
      "component": "SerenityPractitioners",
      "configExport": "serenityPractitionersScrollConfig",
      "contentKey": "practitioners"
    },
    "@velo/testimonials": {
      "component": "Testimonials",
      "configExport": "testimonialsScrollConfig",
      "contentKey": "testimonials",
      "extraProps": { "variant": "serenity" }
    },
    "@velo/serenity-booking": {
      "component": "SerenityBooking",
      "configExport": "serenityBookingScrollConfig",
      "contentKey": "booking"
    },
    "@velo/footer": {
      "component": "Footer",
      "configExport": "footerScrollConfig",
      "contentKey": "footer",
      "extraProps": { "variant": "serenity", "localeSwitcher": "<LocaleSwitcher />" }
    }
  }
}
